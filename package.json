{
  "name": "obsidian-mcp-pro-plugin",
  "version": "0.2.2",
  "description": "Obsidian plugin that runs an MCP server inside the app, exposing the vault to Claude/Cursor/ChatGPT over HTTP.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian-plugin",
    "mcp",
    "obsidian",
    "claude",
    "cursor"
  ],
  "author": "rps321",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.4.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "obsidian-mcp-pro": "^1.3.0"
  }
}
